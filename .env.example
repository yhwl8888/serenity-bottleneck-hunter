# 复制为 .env 并填入你自己的密钥(切勿提交真实 .env)
# Copy to .env and fill in your own key (never commit a real .env)

# EODHD 价格数据(可选,scripts/price.py 与 tracking/score_tracker.py 使用)
# 优先级:EODHD(全球覆盖、海外股推荐) → yfinance(无 key,美股 OK)兜底
# Optional. price.py / score_tracker.py prefer EODHD when this is set;
# they fall back to yfinance (no key needed) otherwise. US tickers work on yfinance;
# non-US (EU / TW / KR / etc.) typically require EODHD.
EODHD_API_KEY=your_eodhd_key_here
